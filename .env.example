# ============================================
# RENDER ENVIRONMENT VARIABLES
# ============================================
# Copy these to Render Dashboard → Your Web Service → Environment
# DO NOT commit this file to Git!

# --------------------------------------------
# DATABASE (PostgreSQL)
# --------------------------------------------
# Get this from Render PostgreSQL → External Database URL
DATABASE_URL=postgres://urlshortner_user:YOUR_PASSWORD@YOUR_HOST.render.com:5432/urlshortner

# --------------------------------------------
# REDIS
# --------------------------------------------
# Get these from Render Redis dashboard
REDIS_HOST=YOUR_REDIS_HOST.render.com
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# --------------------------------------------
# JWT SECURITY (Generate a strong secret!)
# --------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=PASTE_YOUR_GENERATED_SECRET_HERE

# --------------------------------------------
# APP URL
# --------------------------------------------
# Set this AFTER deployment to your Render URL
BASE_URL=https://urlshortner-api.onrender.com

# --------------------------------------------
# OPTIONAL (defaults are fine)
# --------------------------------------------
# JWT_EXPIRATION_MS=86400000
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW=60
# CACHE_TTL_HOURS=24
# LOG_LEVEL=INFO

